# =============================================================================
# Neo4j Connection
# =============================================================================
NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# =============================================================================
# Aura Agent (see MCP.md for setup)
# =============================================================================
AURA_AGENT_ENDPOINT=
AURA_AGENT_CLIENT_ID=
AURA_AGENT_CLIENT_SECRET=
AURA_AGENT_MCP_SERVER=""

# =============================================================================
# AI Provider — pick one: azure, openai, or bedrock
# =============================================================================
EMBEDDING_PROVIDER=azure

# LLM_PROVIDER defaults to EMBEDDING_PROVIDER. Set it to use a different
# provider for the LLM (entity extraction, resolution) vs embeddings.
# LLM_PROVIDER=azure

# Override embedding vector dimensions (default: 1536 for OpenAI/Azure, 1024 for Bedrock)
# EMBEDDING_DIMENSIONS=

# =============================================================================
# Azure AI Foundry (EMBEDDING_PROVIDER=azure)
#   Requires: az login --use-device-code
#   Populate with: uv run python setup_env.py (after azd up)
# =============================================================================
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_NAME=gpt-4o
AZURE_AI_EMBEDDING_NAME=text-embedding-3-small

# =============================================================================
# OpenAI (EMBEDDING_PROVIDER=openai)
# =============================================================================
# OPENAI_API_KEY=

# =============================================================================
# AWS Bedrock (EMBEDDING_PROVIDER=bedrock)
#   Auth: standard boto3 credential chain (~/.aws/credentials, env vars, IAM role)
#   MODEL_ID and EMBEDDING_MODEL_ID are optional — defaults shown below.
# =============================================================================
# AWS_REGION=us-east-1
# MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
